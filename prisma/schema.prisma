generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Sexo {
  M
  F
}

enum OrderStatus {
  pending
  delivered
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre          String
  apellido        String
  sexo            Sexo
  fechaNacimiento DateTime
  correo          String   @unique
  telefono        String
  password        String
  createdAt       DateTime @default(now())

  orders          Order[]
}

model Order {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  numeroOrden           Int       @unique
  direccionRecoleccion  String
  fechaProgramada       DateTime
  nombres               String
  apellidos             String
  correo                String
  telefono              String
  direccionDestinatario String
  departamento          String
  municipio             String
  puntoReferencia       String
  indicaciones          String

  isCOD                 Boolean     @default(false)
  expectedAmount        Float?
  collectedAmount       Float?
  status                OrderStatus @default(pending)
  shippingCost          Float?
  settlementAmount      Float?

  createdAt             DateTime  @default(now())

  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id])

  paquetes              Package[]
}

model Package {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  largo     Float
  alto      Float
  ancho     Float
  peso      Float
  contenido String

  orderId   String  @db.ObjectId
  order     Order   @relation(fields: [orderId], references: [id])
}

model ShippingCost {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  day   String @unique // monday, tuesday, wednesday, thursday, friday, saturday, sunday
  cost  Float
}